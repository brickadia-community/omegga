{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "types": [
      "./src/index.d.ts",
      "../src/webserver/backend/types.d.ts"
    ],
    "paths": {
      "@components": [
        "./src/components"
      ],
      "@utils": [
        "./src/utils"
      ],
      "@hooks": [
        "./src/hooks"
      ],
      "@backend/*": [
        "../src/webserver/backend/*"
      ],
      /* Backend path aliases — mirrored here so tRPC can resolve backend types */
      "@omegga/*": [
        "../src/omegga/*"
      ],
      "@/*": [
        "../src/*"
      ],
      "@util/*": [
        "../src/util/*"
      ],
      "@config/*": [
        "../src/config/*"
      ]
    },
    "baseUrl": "."
  },
  "include": [
    "src"
  ]
}